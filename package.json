{
  "name": "line-liff-card",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "smoke:pages": "bash ./scripts/smoke-pages.sh",
    "provision:google-runtime": "node ./scripts/provision-google-runtime.mjs",
    "google:oauth:bootstrap": "node ./scripts/google-oauth-bootstrap.mjs",
    "gas:setup": "node ./scripts/print-bound-gas-setup.mjs",
    "gas:deploy": "node ./scripts/print-bound-gas-setup.mjs --deploy",
    "gas:check": "bash ./scripts/check-runtime-backend.sh",
    "gas:check:admin": "node ./scripts/check-runtime-admin.mjs",
    "gas:inspect:prod": "node ./scripts/inspect-production-gas.mjs",
    "gas:push:prod": "node ./scripts/push-production-gas.mjs",
    "gas:version:prod": "node ./scripts/create-production-gas-version.mjs",
    "gas:update-deployment:prod": "node ./scripts/update-production-gas-deployment.mjs",
    "gas:verify:prod": "node ./scripts/verify-production-gas.mjs",
    "gas:release:prod": "node ./scripts/release-production-gas.mjs",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@line/liff": "^2.27.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
